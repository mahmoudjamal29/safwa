#### Complete Form Example

```tsx
'use client'

import { PageHeader } from '@/components/custom/page-header'
import { FormCard } from '@/components/custom/form-card'
import { useAppForm } from '@/components/form'

import { usePermissions } from '@/hooks/use-permissions'

import { TenantFormOptions, createTenantSchema } from './form-options'
import { BasicInfoFields } from './forms/basic-info'
import { ContactFields } from './forms/contact'
import { DetailsFields } from './forms/details'
import { PERMISSIONS } from '@/lib/auth/permissions'
import {
  useCreateTenantMutation,
  useUpdateTenantMutation
} from '@/query/tenants'
import { apiFormValidation } from '@/utils'

export const TenantForm: React.FC<{
  isEdit?: boolean
  tenant?: TenantById
}> = ({ isEdit = false, tenant }) => {
  const { hasPermission } = usePermissions()
  const { isPending: isCreating, mutateAsync: createTenant } =
    useCreateTenantMutation()
  const { isPending: isUpdating, mutateAsync: updateTenant } =
    useUpdateTenantMutation()

  const form = useAppForm({
    ...TenantFormOptions(tenant),
    onSubmit: async ({ formApi, value }) => {
      apiFormValidation(
        () =>
          isEdit
            ? updateTenant({
                ...value,
                id: tenant?.id,
                status: value.status ? 1 : 0
              })
            : createTenant({ ...value, status: value.status ? 1 : 0 }),
        formApi
      )
    },
    validators: {
      onChange: createTenantSchema
    }
  })

  return (
    <div className="mb-10 flex flex-col gap-5">
      <PageHeader
        description="Add a new tenant to the system"
        title={isEdit ? 'Edit Tenant' : 'Create Tenant'}
      >
        <form.AppForm>
          <form.SubmitButton
            disabled={
              isEdit
                ? !hasPermission(PERMISSIONS.TENANTS_UPDATE)
                : !hasPermission(PERMISSIONS.TENANTS_CREATE)
            }
            form="create-tenant-form"
            isLoading={isEdit ? isUpdating : isCreating}
          >
            {isEdit ? 'Update Tenant' : 'Create Tenant'}
          </form.SubmitButton>
        </form.AppForm>
      </PageHeader>
      <form
        className="w-full flex-1 space-y-5 px-5"
        id="create-tenant-form"
        onSubmit={(e) => {
          e.preventDefault()
          form.handleSubmit()
        }}
      >
        <BasicInfoFields
          form={form}
          imageUrl={tenant?.image_url ?? undefined}
        />
        <DetailsFields form={form} />
        <ContactFields form={form} />
      </form>
    </div>
  )
}
```

