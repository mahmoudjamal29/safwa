### Handling Edit Mode and Reactive Updates

**CRITICAL**: TanStack Form's `defaultValues` are only used during **initial form creation**. To handle edit mode, **NEVER use useEffect** - instead, update the `defaultValues` by recreating the form instance when data changes. This is done using a `key` prop to force form recreation with fresh `defaultValues`.

#### Pattern 1: Key Prop for Force Remount (Recommended)

Use this pattern for modal/dialog forms that can be opened with different data:

```typescript
'use client'

import { useAppForm } from '@/components/form'
import { FeatureFormOptions, FeatureSchema } from './form-options'

interface FeatureModalProps {
  feature?: Feature
  isEdit?: boolean
  isOpen: boolean
  onClose: () => void
}

export function FeatureModal({
  feature,
  isEdit = false,
  isOpen,
  onClose
}: FeatureModalProps) {
  // ✅ Form is created with current feature data
  const form = useAppForm({
    ...FeatureFormOptions(feature), // This provides defaultValues based on feature
    onSubmit: async ({ value, formApi }) => {
      // Handle submission
    },
    validators: {
      onChange: featureSchema
    }
  })

  const handleClose = () => {
    onClose()
  }

  return (
    <Dialog onOpenChange={handleClose} open={isOpen}>
      <DialogContent>
        {/* ✅ Key forces remount with fresh defaultValues when feature changes */}
        <form
          key={feature?.id || 'new'}
          onSubmit={(e) => {
            e.preventDefault()
            e.stopPropagation()
            form.handleSubmit()
          }}
        >
          {/* Form fields */}
        </form>
      </DialogContent>
    </Dialog>
  )
}
```

**Key Points:**

- ✅ Simple and clean - no useEffect needed
- ✅ Form is recreated with fresh `defaultValues` when feature changes
- ✅ Complete remount ensures fresh state
- ✅ Key should be the entity ID or 'new' for create mode

#### Pattern 2: useMemo for Conditional Form Creation (Alternative)

Use this pattern when you want more control over form recreation:

```typescript
import { useMemo } from 'react'

export function FeatureModal({
  feature,
  isEdit = false,
  isOpen,
  onClose
}: FeatureModalProps) {
  // ✅ Create new form instance when feature changes
  const formKey = feature?.id || 'new'

  const form = useMemo(
    () =>
      useAppForm({
        ...FeatureFormOptions(feature), // Re-evaluated when formKey changes
        onSubmit: async ({ value, formApi }) => {
          // Handle submission
        },
        validators: {
          onChange: featureSchema
        }
      }),
    [formKey] // Recreate form when key changes
  )

  return (
    <Dialog onOpenChange={onClose} open={isOpen}>
      <DialogContent>
        <form
          onSubmit={(e) => {
            e.preventDefault()
            e.stopPropagation()
            form.handleSubmit()
          }}
        >
          {/* Form fields */}
        </form>
      </DialogContent>
    </Dialog>
  )
}
```

**Key Points:**

- ✅ More control over when form is recreated
- ✅ Can include additional dependencies if needed
- ✅ Requires careful dependency management

#### Best Practice: Update defaultValues Through Form Recreation

**Always handle edit mode by updating defaultValues through form recreation, NOT useEffect:**

```typescript
// ✅ CORRECT - Recreate form with fresh defaultValues
export function FeatureModal({ feature, isEdit, isOpen, onClose }: Props) {
  const form = useAppForm({
    ...FeatureFormOptions(feature), // defaultValues updated when form recreates
    onSubmit: async ({ value, formApi }) => {
      // Handle submission
    },
    validators: {
      onChange: featureSchema
    }
  })

  return (
    <Dialog onOpenChange={onClose} open={isOpen}>
      <DialogContent>
        {/* Key ensures form recreates with fresh defaultValues */}
        <form key={feature?.id || 'new'} onSubmit={(e) => {
          e.preventDefault()
          e.stopPropagation()
          form.handleSubmit()
        }}>
          {/* Form fields */}
        </form>
      </DialogContent>
    </Dialog>
  )
}

// ❌ WRONG - Never use useEffect to update form values in edit mode
export function FeatureModal({ feature, isEdit, isOpen, onClose }: Props) {
  const form = useAppForm({
    ...FeatureFormOptions(feature),
    onSubmit: async ({ value, formApi }) => {
      // Handle submission
    }
  })

  // ❌ DON'T DO THIS - Use form recreation instead
  useEffect(() => {
    if (feature) {
      form.setFieldValue('name', feature.name)
      form.setFieldValue('email', feature.email)
    }
  }, [feature, isOpen])

  return (
    // ... component JSX
  )
}
```

#### Common Mistakes to Avoid

```typescript
// ❌ WRONG - Form won't update when feature changes (missing key)
const form = useAppForm({
  ...FeatureFormOptions(feature),
  onSubmit: async ({ value }) => { /* ... */ }
})

return (
  <form onSubmit={...}>
    {/* Missing key prop - form won't recreate when feature changes */}
  </form>
)

// ❌ WRONG - Using useEffect to sync form state
useEffect(() => {
  if (feature) {
    form.setFieldValue('name', feature.name)
    form.setFieldValue('email', feature.email)
  }
}, [feature, isOpen])
// Never use useEffect for edit mode - update defaultValues instead

// ❌ WRONG - Converting numeric status (0/1) to boolean with falsy fallback
// When status is 0, the ternary condition is falsy, so it returns the fallback (true) instead of false
status: tenant?.status ? !!tenant.status : true,  // Returns true when status is 0!
status: defaultValues?.status ? !!defaultValues?.status : true,  // Same issue
status: shift ? shift.status === StatusEnum.ACTIVE : true,  // Wrong fallback value

// ✅ CORRECT - Converting numeric status (0/1) to boolean
// Use nullish coalescing to handle 0 correctly, then compare to enum
status: (tenant?.status ?? 0) === StatusEnum.ACTIVE,  // Best pattern - handles 0, 1, and undefined
status: tenant?.status === StatusEnum.ACTIVE ? true : false,  // Also correct
status: tenant?.status !== undefined ? tenant.status === StatusEnum.ACTIVE : false,  // Explicit undefined check

// ✅ CORRECT - Use key prop to recreate form with fresh defaultValues
const form = useAppForm({
  ...FeatureFormOptions(feature),
  onSubmit: async ({ value }) => { /* ... */ }
})

return (
  <form key={feature?.id || 'new'} onSubmit={...}>
    {/* Key ensures form recreates with updated defaultValues */}
  </form>
)
```

#### Data Transformation in Edit Mode

When API data structure differs from form structure, handle transformations in formOptions:

```typescript
// form-options.ts
export const BranchFormOptions = (branch?: TenantBranch) =>
  formOptions({
    defaultValues: {
      // Transform API structure to form structure
      title_en: branch?.name || '', // API has single 'name', form needs 'title_en'
      title_ar: branch?.name || '', // Same for Arabic
      address: branch?.address || '',
      email: branch?.email || '',
      phone: branch?.phone || '',
      latitude: branch?.latitude ? parseFloat(branch.latitude) : undefined,
      longitude: branch?.longitude ? parseFloat(branch.longitude) : undefined
    } as BranchFormSchema,
    validators: {
      onChange: branchFormSchema
    }
  })

// component.tsx - No transformations needed here, handled in formOptions
export function BranchModal({ branch, isOpen, onClose }: Props) {
  const form = useAppForm({
    ...BranchFormOptions(branch), // Transformations happen here
    onSubmit: async ({ value, formApi }) => {
      // Handle submission
    },
    validators: {
      onChange: branchFormSchema
    }
  })

  return (
    <Dialog onOpenChange={onClose} open={isOpen}>
      <DialogContent>
        {/* Key ensures form recreates when branch changes */}
        <form key={branch?.id || 'new'} onSubmit={...}>
          {/* Form fields */}
        </form>
      </DialogContent>
    </Dialog>
  )
}
```

**Key Points:**

- ✅ All data transformations happen in `formOptions`
- ✅ No need to repeat transformations elsewhere
- ✅ Form recreates with fresh transformed data via key prop

### withForm HOC Usage

The `withForm` HOC allows you to create reusable form field group components. **Always use inline `function Render` pattern with proper type inference:**

```typescript
import { withForm } from '@/components/form'
import { TenantsFormOptions } from './form-options'

export const BasicInfoFields = withForm({
  ...TenantsFormOptions({}), // ✅ Use FormOptions() for types
  render: function Render({ form }) {
    // ✅ No type annotations needed - withForm provides proper types
    // ✅ Can use hooks (useQuery, useStore, etc.) inside render function
    // ✅ TypeScript infers form type correctly

    return (
      <FormCard id="basic-info" title="Basic Info">
        <form.AppField name="en.name">
          {(field) => <field.Input label="Title (English)" />}
        </form.AppField>
        <form.AppField name="ar.name">
          {(field) => <field.Input label="Title (Arabic)" />}
        </form.AppField>
        <form.AppField name="status">
          {(field) => <field.Switch label="Status" />}
        </form.AppField>
      </FormCard>
    )
  }
})

// Usage in main form component
function TenantForm({ tenant }: { tenant?: TenantById }) {
  const form = useAppForm({
    ...TenantsFormOptions(tenant),
    onSubmit: async ({ value, formApi }) => {
      // Handle submission
    },
    validators: {
      onChange: createTenantSchema
    }
  })

  return (
    <form
      onSubmit={(e) => {
        e.preventDefault()
        e.stopPropagation()
        form.handleSubmit()
      }}
    >
      <BasicInfoFields form={form} />
      {/* Other field groups */}
    </form>
  )
}
```

**⚠️ CRITICAL: `defaultValues` in `withForm` is Only for Types**

**The `defaultValues` property in `withForm` is ONLY used for TypeScript type inference. It does NOT need to match the actual runtime values or require props that the form options function needs.**

**⚠️ CRITICAL: Form Sections MUST Use `withForm`**

**ALL form section components (components that render form fields grouped in cards/sections) MUST use `withForm` HOC instead of `useFormContext()`. This ensures proper form context and type safety.**

**⚠️ CRITICAL: Forms with More Than 2 Sections MUST Use Dynamic Imports**

**When a form has more than 2 sections, each section component MUST be dynamically imported using `next/dynamic` for code splitting and performance optimization.**

**✅ CORRECT - Forms with 3+ sections using dynamic imports:**

```typescript
'use client'

import dynamic from 'next/dynamic'

import { FormCardSkeleton } from '@/components/custom/form-card-skeleton'

// Code splitting: Lazy load form sections
const BasicInfoFields = dynamic(
  () =>
    import('./sections').then((mod) => ({
      default: mod.BasicInfoFields
    })),
  {
    loading: () => <FormCardSkeleton />,
    ssr: false
  }
)

const LocationFields = dynamic(
  () =>
    import('./sections').then((mod) => ({
      default: mod.LocationFields
    })),
  {
    loading: () => <FormCardSkeleton />,
    ssr: false
  }
)

const DescriptionFields = dynamic(
  () =>
    import('./sections').then((mod) => ({
      default: mod.DescriptionFields
    })),
  {
    loading: () => <FormCardSkeleton />,
    ssr: false
  }
)

// Usage in form component
export const ResourceForm: React.FC<ResourceFormProps> = ({ ... }) => {
  const form = useAppForm({ ... })

  return (
    <form>
      <BasicInfoFields form={form} />
      <LocationFields form={form} />
      <DescriptionFields form={form} />
    </form>
  )
}
```

**❌ WRONG - Forms with 3+ sections without dynamic imports:**

```typescript
'use client'

import { BasicInfoFields } from './sections'
import { LocationFields } from './sections'
import { DescriptionFields } from './sections'

// ❌ WRONG: Direct imports for forms with 3+ sections
export const ResourceForm: React.FC<ResourceFormProps> = ({ ... }) => {
  // ...
}
```

**Key Requirements:**

- ✅ **Forms with 3+ sections**: MUST use `dynamic()` imports
- ✅ **Forms with 2 or fewer sections**: Can use direct imports
- ✅ **Loading state**: Use `FormCardSkeleton` as loading component
- ✅ **SSR**: Set `ssr: false` for client-only form sections
- ✅ **Section organization**: Place all section components in a `sections/` folder with an `index.ts` barrel export

**❌ WRONG - Using `useFormContext()` in sections:**

```typescript
'use client'
import { useFormContext } from '@/components/form'

export const BasicInfo: React.FC = () => {
  const form = useFormContext() // ❌ WRONG: Sections must use withForm
  return (
    <FormCard title="Basic Info">
      <form.AppField name="name">
        {(field) => <field.Input label="Name" />}
      </form.AppField>
    </FormCard>
  )
}
```

**✅ CORRECT - Using `withForm` for sections:**

```typescript
'use client'
import { withForm } from '@/components/form'
import { UsersFormDefaultValues } from './form-options'

export const BasicInfo = withForm({
  ...UsersFormOptions(),
  render: function Render({ form }) {
    return (
      <FormCard id="basic-info" title="Basic Info">
        <form.AppField name="name">
          {(field) => <field.Input label="Name" />}
        </form.AppField>
      </FormCard>
    )
  }
})
```

**⚠️ CRITICAL: Passing Data to `withForm` Components**

**To pass data to `withForm` components, use the `props` object in the `withForm` configuration. Define props with type assertions and access them in the render function.**

**❌ WRONG - Accessing data from form state:**

```typescript
// ❌ WRONG: Don't store non-form data in form schema
export const UsersFormSchema = (t: Translations<'forms.validation'>) => {
  const schema = z.object({
    image: z.instanceof(File).optional().nullable(),
    image_url: z.string().optional().nullable() // ❌ WRONG: Not a form field
    // ... other fields
  })
}

// ❌ WRONG: Don't access from form state
export const BasicInfo = withForm({
  defaultValues: UsersFormDefaultValues,
  props: {},
  render: function Render({ form }) {
    // ❌ WRONG: Accessing non-form data from form state
    const existingImageUrl = form.state.values.image_url as
      | string
      | null
      | undefined
    // ...
  }
})
```

**✅ CORRECT - Passing data through props:**

```typescript
// form-options.ts - Only include actual form fields
export const UsersFormSchema = (t: Translations<'forms.validation'>) => {
  const schema = z.object({
    image: z.instanceof(File).optional().nullable(),
    // ✅ CORRECT: Don't include non-form data in schema
    // ... other form fields
  })
}

// basic-info.tsx - Define props type and pass through props object
type BasicInfoProps = {
  existingImageUrl?: string | null
}

export const BasicInfo = withForm({
  defaultValues: UsersFormDefaultValues,
  props: {
    existingImageUrl: undefined as string | null | undefined
  } as BasicInfoProps,
  render: function Render({ form, existingImageUrl }) {
    // ✅ CORRECT: Access prop from render function parameters
    return (
      <FormCard title="Basic Info">
        <form.AppField name="image">
          {(field) => {
            const imageSrc =
              field.state.value instanceof File
                ? URL.createObjectURL(field.state.value)
                : existingImageUrl || undefined
            return <field.ImageComponent src={imageSrc} />
          }}
        </form.AppField>
      </FormCard>
    )
  }
})

// users-form.tsx - Pass props when using the component
<BasicInfo form={form} existingImageUrl={user?.image_url} />
```

**Key Pattern:**

- ✅ **Define props type** - Create a type for the props (e.g., `type BasicInfoProps = { existingImageUrl?: string | null }`)
- ✅ **Type props object** - Use `props: { propName: undefined as Type } as PropsType` pattern
- ✅ **Access in render** - Destructure props from render function parameters: `render: function Render({ form, propName })`
- ✅ **Pass when using** - Pass props when using the component: `<BasicInfo form={form} existingImageUrl={value} />`
- ❌ **Don't store in form schema** - Don't add non-form data to the form schema
- ❌ **Don't access from form state** - Don't use `form.state.values` for non-form data

**⚠️ CRITICAL: `defaultValues` Parameter Type in Form Options Functions**

**When creating form options functions that accept `defaultValues` parameter, the type MUST be the schema type directly, NOT `Partial<SchemaType>` or a utility type.**

**✅ CORRECT:**

```typescript
export const useGroupsFormOptions = (defaultValues?: GroupsFormSchema) => {
  // ✅ CORRECT: Use schema type directly
  const t = useTranslations('forms.validation')
  return formOptions({
    defaultValues: {
      ...GroupsFormDefaultValues,
      ...defaultValues
    },
    validators: {
      onChange: GroupsFormSchema(t)
    }
  })
}
```

**Key Points:**

- ✅ **Always use inline `function Render({ form })` pattern** - no separate function declaration
- ✅ **No type annotations needed** - `withForm` HOC provides proper TypeScript inference
- ✅ **No `any` types or eslint-disable comments** - the inline function pattern avoids hooks rule issues
- ✅ **`defaultValues` type must match parent form** - The `defaultValues` type in `withForm` should match the `defaultValues` type from the original form
- ✅ **Use exported default values constant** - Use `{Feature}DV` or `{Feature}FormDefaultValues` directly, not `FormOptions({}).defaultValues`
- ✅ **Always use `form.AppField` for field rendering**
- ✅ **Can use hooks (useQuery, useStore, etc.) inside render function**
- ✅ **Form sections MUST use `withForm`** - Never use `useFormContext()` in section components
- ✅ **Pass data through form state** - Store in `defaultValues` and access via `form.state.values`
- ✅ **`defaultValues` parameter type** - Always use the schema type directly in form options functions

**✅ CORRECT Pattern - Use Exported Default Values Constant:**

```typescript
// form-options.ts
import { formOptions, FormValidateOrFn } from '@tanstack/react-form-nextjs'
import { z } from 'zod'

// 1. Define validation schema (as function that returns zod schema)
export const parentsFormSchema = () =>
  z.object({
    address: z.string(),
    address_latitude: z.number(),
    address_longitude: z.number(),
    blocked: z.string(),
    email: z.string(),
    image: z.instanceof(File).optional(),
    mode: z.string(),
    name: z.string(),
    parent_id: z.string(),
    password: z.string(),
    password_confirmation: z.string(),
    phone: z.string(),
    preferable_language: z.string(),
    status: z.string(),
    tenant_id: z.string()
  })

// 2. Export schema type
export type ParentsFormSchema = z.infer<
  ReturnType<typeof parentsFormSchema>
>

// 3. Declare default values in separate exported constant
export const ParentsDV: ParentsFormSchema = {
  address: '',
  address_latitude: 0,
  address_longitude: 0,
  blocked: '0',
  email: '',
  image: undefined,
  mode: 'create',
  name: '',
  parent_id: '',
  password: '',
  password_confirmation: '',
  phone: '',
  preferable_language: 'en',
  status: '1',
  tenant_id: ''
}

// 4. Create form options function
type ParentsFormOptionsProps = {
  tenant?: Tenant
  t?: Translations<'riders.forms.parent.validation'>
  tPhone?: Translations<'components.form.validation'>
}

export const ParentsFormOptions = ({
  tenant,
  t,
  tPhone
}: ParentsFormOptionsProps = {}) =>
  formOptions({
    defaultValues: {
      ...ParentsDV,
      tenant_id: tenant?.id.toString() ?? ParentsDV.tenant_id
    } as ParentsFormSchema,
    ...(t && tPhone && {
      validators: {
        onChange: parentsFormSchema({ t, tPhone }) as FormValidateOrFn<ParentsFormSchema>
      }
    })
  })

// Component using withForm
import { ParentsDV } from './form-options'

const CreateParentFields = withForm({
  defaultValues: ParentsDV, // ✅ Use exported default values constant directly (not calling function)
  props: {}, // ✅ Empty props object
  render: function Render({ form }) {
    const t = useTranslations('riders.forms.parent')
    // ✅ Can use hooks inside render function
    return (
      <div className="space-y-6">
        <form.AppField name="name">
          {(field) => <field.Input label={t('fullNameLabel')} />}
        </form.AppField>
        {/* ... other fields */}
      </div>
    )
  }
})
```

**❌ WRONG Pattern - Passing Props to Form Options:**

```typescript
// ❌ DON'T: Pass dummy functions to form options in withForm
const CreateParentFields = withForm({
  ...ParentsFormOptions({
    t: () => '', // ❌ Wrong: Dummy function doesn't match Translations type
    tPhone: () => '' // ❌ Wrong: Dummy function doesn't match Translations type
  }),
  render: function Render({ form }) {
    // ...
  }
})

// ❌ DON'T: Include validators in withForm when validation is handled by parent
const AssignParentFields = withForm({
  defaultValues: defaultParentFormValues,
  validators: {
    onChange: () => ({}) // ❌ Wrong: Type mismatch, validation handled by parent
  },
  props: {
    /* ... */
  },
  render: function Render({ form }) {
    // ...
  }
})
```

**✅ CORRECT Pattern - No Validators When Parent Handles Validation:**

```typescript
// ✅ DO: Omit validators when parent form handles validation
const AssignParentFields = withForm({
  defaultValues: defaultParentFormValues, // ✅ Only for types
  props: {
    parentOptions: [] as User[],
    parentsLoading: false as boolean,
    tenant: {} as Tenant
  },
  render: function Render({ form, parentOptions, parentsLoading, tenant }) {
    // Validation is handled by parent form, this is just for structure
    return (
      <div>
        <form.AppField name="parent_id">
          {(field) => (
            <field.Combobox
              data={parentOptions}
              label="Parent"
              // ...
            />
          )}
        </form.AppField>
      </div>
    )
  }
})
```

**❌ Avoid These Anti-Patterns:**

```typescript
// ❌ DON'T: Separate function declaration with any types
function Render({ form }: { form: any }) {
  // ...
}
export const Component = withForm({
  ...FormOptions(),
  render: Render
})

// ❌ DON'T: Using any types or eslint-disable comments
export const Component = withForm({
  ...FormOptions(),
  render: ({ form }: { form: any }) => {
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const value = useStore(form.store, (state: any) => state.values.field)
  }
})

// ✅ DO: Inline function Render with type inference
export const Component = withForm({
  ...FormOptions(),
  render: function Render({ form }) {
    const value = useStore(form.store, (state) => state.values.field)
    // TypeScript infers types correctly
  }
})
```

### State Subscription (for Debugging)

```typescript
import { useStore } from '@tanstack/react-form'

// Subscribe to specific form state for debugging
const form = useAppForm({
  /* ... */
})

useStore(form.store, (state) => {
  console.log('Form errors:', state.errors)
  console.log('Form values:', state.values)
})
```

### Form Section Code Splitting Pattern (REQUIRED)

**⚠️ CRITICAL: ALL form section components MUST be lazy-loaded using Next.js `dynamic` imports for code splitting.**

**Why:**

- **Reduces initial bundle size** - Form sections are split into separate chunks
- **Improves page load performance** - Only loads form sections when needed
- **Better user experience** - Faster initial page renders

**✅ CORRECT - Using dynamic imports for form sections:**

```typescript
'use client'

import dynamic from 'next/dynamic'

import { FormCardSkeleton } from '@/components/custom/form-card-skeleton'

// Code splitting: Lazy load form sections
const BasicInfoFields = dynamic(
  () =>
    import('@/components/forms/profile').then((mod) => ({
      default: mod.BasicInfoFields
    })),
  {
    loading: () => <FormCardSkeleton  />,
    ssr: false
  }
)

const PermissionsFields = dynamic(
  () =>
    import('@/components/forms/profile').then((mod) => ({
      default: mod.PermissionsFields
    })),
  {
    loading: () => <FormCardSkeleton  />,
    ssr: false
  }
)

export function AdminForm() {
  const form = useAppForm({
    // ... form configuration
  })

  return (
    <form>
      <BasicInfoFields form={form} />
      <PermissionsFields form={form} />
    </form>
  )
}
```

**For local form sections (same feature folder):**

```typescript
'use client'

import dynamic from 'next/dynamic'

import { FormCardSkeleton } from '@/components/custom/form-card-skeleton'

// Code splitting: Lazy load form sections from local feature folder
const BasicInfoFields = dynamic(
  () =>
    import('./basic-info').then((mod) => ({
      default: mod.BasicInfoFields
    })),
  {
    loading: () => <FormCardSkeleton  />,
    ssr: false
  }
)

const PermissionsFields = dynamic(
  () =>
    import('./permissions').then((mod) => ({
      default: mod.PermissionsFields
    })),
  {
    loading: () => <FormCardSkeleton  />,
    ssr: false
  }
)
```

**❌ WRONG - Direct imports (no code splitting):**

```typescript
// ❌ WRONG: Direct imports prevent code splitting
import { BasicInfoFields } from './basic-info'
import { PermissionsFields } from './permissions'

export function AdminForm() {
  // ...
}
```

**Key Requirements:**

1. **✅ Use `dynamic` from `next/dynamic`** - Required for lazy loading
2. **✅ Use `.then((mod) => ({ default: mod.ComponentName }))` pattern** - Required for named exports
3. **✅ Set `ssr: false`** - Form sections are client-only components
4. **✅ Import `FormCardSkeleton` at top level** - Needed for loading component

**Pattern Breakdown:**

```typescript
const ComponentName = dynamic(
  () =>
    import('./path/to/module').then((mod) => ({
      default: mod.ComponentName // Named export becomes default export
    })),
  {
    loading: () => <FormCardSkeleton  />, // Loading state
    ssr: false // Disable SSR for client-only components
  }
)
```

**Benefits:**

- Smaller initial JavaScript bundles
- Faster Time to Interactive (TTI)
- Better Core Web Vitals scores
- Improved performance on slower devices/networks
- Components load on-demand when form sections are rendered

## Field Component Usage

### Label Prop Pattern (CRITICAL - Always Use Label Props)

**NEVER use hardcoded labels with custom HTML structure** - Always use the `label` prop provided by form field components. This ensures consistent styling, alignment, and accessibility across all form fields.

#### ✅ CORRECT - Use Label Prop

```typescript
// ✅ CORRECT - Use label prop on field components
<form.AppField name="name">
  {(field) => (
    <field.Input label="Name" placeholder="Enter name" />
  )}
</form.AppField>

<form.AppField name="email">
  {(field) => (
    <field.Input label="Email Address" placeholder="Enter email" type="email" />
  )}
</form.AppField>

<form.AppField name="tenant_type">
  {(field) => (
    <field.Select
      label="Tenant Type"
      optionKey="key"
      options={tenantTypeOptions}
      optionValue="label"
      placeholder="Select tenant type..."
    />
  )}
</form.AppField>

<form.AppField name="tenant_id">
  {(field) => (
    <field.Combobox
      label="Tenant"
      data={tenants}
      labelKey="name"
      valueKey="id"
      placeholder="Select tenant..."
    />
  )}
</form.AppField>

<form.AppField name="password">
  {(field) => (
    <field.Password label="New Password" placeholder="Enter new password" />
  )}
</form.AppField>
```

#### ❌ WRONG - Never Use Hardcoded Labels

```typescript
// ❌ WRONG - Never create custom label structure
<form.AppField name="name">
  {(field) => (
    <div className="flex items-start gap-8">
      <label
        className="text-muted-foreground w-24 pt-3 text-sm font-medium"
        htmlFor={field.name}
      >
        Name
      </label>
      <div className="flex-1">
        <field.Input className="w-full" placeholder="Enter name" />
      </div>
    </div>
  )}
</form.AppField>

// ❌ WRONG - Never wrap fields in custom flex containers for labels
<form.AppField name="email">
  {(field) => (
    <div className="flex items-start gap-8">
      <label className="text-muted-foreground w-24 pt-3 text-sm font-medium">
        Email
      </label>
      <div className="flex-1">
        <field.Input className="w-full" placeholder="Enter email" />
      </div>
    </div>
  )}
</form.AppField>
```

#### Why Use Label Props?

1. **Consistent Alignment** - All form components use the same label structure (`w-full flex-shrink-0 lg:w-1/6`) ensuring perfect vertical and horizontal alignment
2. **Responsive Design** - Labels automatically adapt to screen size (stacked on mobile, side-by-side on desktop)
3. **Accessibility** - Proper `htmlFor` attributes and label associations are handled automatically
4. **Maintainability** - Changes to label styling only need to be made in one place (the component)
5. **Type Safety** - Label prop is typed and validated by TypeScript

#### Available Form Field Components with Label Props

All form field components support the `label` prop:

- `field.Input` - Text input fields
- `field.Password` - Password input with visibility toggle
- `field.Select` - Dropdown select fields
- `field.Combobox` - Autocomplete/combobox fields
- `field.PhoneInput` - Phone number input with country selector
- `field.TextArea` - Multi-line text input
- `field.DatePicker` - Date picker fields
- `field.MapSelector` - Map-based location selector
- `field.SingleImageUpload` - Image upload component
- `field.MultiSelect` - Multi-select dropdown
- `field.Switch` - Toggle switch (uses different structure)

#### Special Cases

**Switch Component** - Uses a different structure but still supports `label` prop:

```typescript
<form.AppField name="status">
  {(field) => (
    <field.Switch label="Status" />
  )}
</form.AppField>
```

**SingleImageUpload** - Supports `label` prop for consistent alignment:

```typescript
<form.AppField name="image">
  {(field) => (
    <field.SingleImageUpload
      label="Photo"
      isAvatar={true}
      allowedTypes={['image/jpg', 'image/jpeg']}
    />
  )}
</form.AppField>
```

**Phone Number Fields** - **CRITICAL: Always use standardized phone validation and PhoneInput component**

**⚠️ REQUIRED PATTERN**: All phone/mobile fields MUST follow this standardized pattern:

1. **Schema Validation**: Always use `zodPhoneNumberSchema` from `@/components/form` for phone field validation
2. **Optional Fields**: Use `.optional()` for optional phone fields (e.g., `zodPhoneNumberSchema.optional()`)
3. **Component Usage**: Always use `field.PhoneInput` component (never use `field.Input` for phone fields)

**✅ CORRECT - Required Phone Field:**

```typescript
// form-options.ts
import { zodPhoneNumberSchema } from '@/components/form'
import { z } from 'zod'

export const createFeatureSchema = z.object({
  phone: zodPhoneNumberSchema // Required field
  // ... other fields
})
```

```typescript
// form.tsx
<form.AppField name="phone">
  {(field) => (
    <field.PhoneInput
      label="Phone Number"
      placeholder="Enter phone number"
    />
  )}
</form.AppField>
```

**✅ CORRECT - Optional Phone Field:**

```typescript
// form-options.ts
import { zodPhoneNumberSchema } from '@/components/form'
import { z } from 'zod'

export const createFeatureSchema = z.object({
  phone: zodPhoneNumberSchema.optional(), // Optional field
  alternate_phone: zodPhoneNumberSchema.optional(), // Optional alternate phone
  emergency_contact: zodPhoneNumberSchema.optional() // Optional emergency contact
  // ... other fields
})
```

```typescript
// form.tsx
<form.AppField name="phone">
  {(field) => (
    <field.PhoneInput
      label="Phone Number"
      placeholder="Enter phone number"
    />
  )}
</form.AppField>
```

**❌ WRONG - Never use custom validation or Input component:**

```typescript
// ❌ DON'T: Custom phone validation
phone: z.string().min(10, 'Phone number must be at least 10 characters'),
phone: z.string().min(5, 'Phone number is required'),
phone: z.string().optional().refine((val) => {
  if (!val || val === '') return true
  return val.length >= 10 && val.length <= 15
}, {
  message: 'Phone number must be between 10 to 15 characters if provided'
}),

// ❌ DON'T: Using Input component for phone fields
<form.AppField name="phone">
  {(field) => (
    <field.Input label="Phone Number" type="tel" />
  )}
</form.AppField>
```

**Phone Field Schema Details:**

The `zodPhoneNumberSchema` from `@/components/form` provides:

- Minimum 13 digits validation
- Regex pattern validation (`/^\+?\d+$/`)
- Consistent error messages across all forms
- International phone number format support

**Import Pattern:**

```typescript
import { zodPhoneNumberSchema } from '@/components/form'
```

**Field Names That Should Use This Pattern:**

- `phone` - Primary phone number
- `mobile` - Mobile phone number
- `alternate_phone` - Alternate phone number
- `alternate_number` - Alternate number
- `emergency_contact` - Emergency contact phone number

**Complete Example:**

```typescript
// form-options.ts
import { formOptions } from '@tanstack/react-form'
import { z } from 'zod'
import { zodPhoneNumberSchema } from '@/components/form'
import { FeatureById } from '@/query/features'

export const createFeatureSchema = z.object({
  name: z.string().min(1, { message: 'Name is required' }),
  phone: zodPhoneNumberSchema, // Required phone
  alternate_phone: zodPhoneNumberSchema.optional(), // Optional phone
  email: z.string().email({ message: 'Invalid email format' })
})

export type CreateFeatureSchema = z.infer<typeof createFeatureSchema>

export const FeatureFormOptions = (feature?: FeatureById) =>
  formOptions({
    defaultValues: {
      name: feature?.name || '',
      phone: feature?.phone || '',
      alternate_phone: feature?.alternate_phone || '',
      email: feature?.email || ''
    } as CreateFeatureSchema,
    validators: {
      onChange: createFeatureSchema
    }
  })
```

```typescript
// form.tsx
<form.AppField name="phone">
  {(field) => (
    <field.PhoneInput
      label="Phone Number"
      placeholder="Enter phone number"
    />
  )}
</form.AppField>

<form.AppField name="alternate_phone">
  {(field) => (
    <field.PhoneInput
      label="Alternate Phone"
      placeholder="Enter alternate phone number"
    />
  )}
</form.AppField>
```

#### Migration from Hardcoded Labels

If you find existing code with hardcoded labels, migrate it to use label props:

```typescript
// Before (❌ WRONG)
<form.AppField name="name">
  {(field) => (
    <div className="flex items-start gap-8">
