      </div>
    </div>
  )}
</form.AppField>

// After (✅ CORRECT)
<form.AppField name="name">
  {(field) => (
    <field.Input label="Name" placeholder="Enter name" />
  )}
</form.AppField>
```

## Common Patterns

### Form Submission with Permissions

```typescript
import { usePermissions } from '@/hooks/use-permissions'
import { PERMISSIONS } from '@/lib/auth/permissions'

// ✅ Project Standard - Use formOptions pattern with permissions
// form-options.ts
export const FeatureFormOptions = (data?: Feature) =>
  formOptions({
    defaultValues: { /* ... */ },
    validators: { onChange: schema }
  })

// Component
export const FeatureForm: React.FC<{ isEdit?: boolean; feature?: Feature }> = ({
  isEdit = false,
  feature
}) => {
  const { hasPermission } = usePermissions()
  const { isPending: isCreating, mutateAsync: createFeature } =
    useCreateFeatureMutation()
  const { isPending: isUpdating, mutateAsync: updateFeature } =
    useUpdateFeatureMutation()

  const form = useAppForm({
    ...FeatureFormOptions(feature), // Spread form options
    onSubmit: async ({ value, formApi }) => {
      // Handle submission with apiFormValidation helper
      apiFormValidation(
        () =>
          isEdit
            ? updateFeature({ ...value, id: feature?.id })
            : createFeature(value),
        formApi
      )
    }
  })

  return (
    <form onSubmit={(e) => {
      e.preventDefault()
      e.stopPropagation()
      form.handleSubmit()
    }}>
      {/* Form fields */}

      <form.AppForm>
        <form.SubmitButton
          disabled={
            isEdit
              ? !hasPermission(PERMISSIONS.FEATURES_UPDATE)
              : !hasPermission(PERMISSIONS.FEATURES_CREATE)
          }
          isLoading={isEdit ? isUpdating : isCreating}
        >
          {isEdit ? 'Update Feature' : 'Create Feature'}
        </form.SubmitButton>
      </form.AppForm>
    </form>
  )
}
```

### Form Layout Pattern (Required Structure)

**⚠️ CRITICAL: Follow this exact structure based on component type**

**For Page Components (direct PageHeader + form):**

