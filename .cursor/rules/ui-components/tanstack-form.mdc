      <Section2Fields form={form} />
    </form>
  </div>
</>
```

**For Form Components (reusable form components):**

**Pattern A: PageHeader outside form (standard pattern):**

```tsx
<div className="mb-10 flex flex-col gap-5">
  <PageHeader description="..." title="...">
    <form.AppForm>
      <form.SubmitButton form="form-id">Submit</form.SubmitButton>
    </form.AppForm>
  </PageHeader>
  <form
    className="w-full flex-1 space-y-5 px-5"
    id="form-id"
    onSubmit={(e) => {
      e.preventDefault()
      form.handleSubmit()
    }}
  >
    <Section1Fields form={form} />
    <Section2Fields form={form} />
  </form>
</div>
```

**Pattern B: PageHeader inside form (centers-form pattern):**

```tsx
<form id="form-id">
  <PageHeader description="..." title="...">
    <form.AppForm>
      <form.SubmitButton form="form-id" isLoading={form.state.isSubmitting}>
        Submit
      </form.SubmitButton>
    </form.AppForm>
  </PageHeader>
  <div className="space-y-5">
    <Section1Fields form={form} />
    <Section2Fields form={form} />
  </div>
</form>
```

**When to use Pattern B:**

- When the form component is self-contained and manages its own PageHeader
- When the form is used in pages that don't need separate PageHeader
- Follows the centers-form.tsx pattern for consistency

