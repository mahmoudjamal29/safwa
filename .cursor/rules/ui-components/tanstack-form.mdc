### Modal/Dialog Form Pattern (Complete Example)

**When creating forms in modals/dialogs with edit mode, always follow this complete pattern:**

```typescript
'use client'

import { AnyFormApi } from '@tanstack/react-form'
import { Save, X } from 'lucide-react'
import { toast } from 'sonner'

import { useAppForm } from '@/components/form'
import { Button } from '@/components/ui/button'
import { Dialog, DialogContent, DialogFooter, DialogHeader, DialogTitle } from '@/components/ui/dialog'
import {
  FeatureFormOptions,
  FeatureFormSchema,
  featureFormSchema
} from './form-options'
import { Feature, useCreateFeatureMutation, useUpdateFeatureMutation } from '@/query/features'
import { apiFormValidation } from '@/utils'

interface FeatureModalProps {
  feature?: Feature
  isEdit?: boolean
  isOpen: boolean
  onClose: () => void
}

export function FeatureModal({
  feature,
  isEdit = false,
  isOpen,
  onClose
}: FeatureModalProps) {
  const { isPending: isCreating, mutateAsync: createFeature } =
    useCreateFeatureMutation()
  const { isPending: isUpdating, mutateAsync: updateFeature } =
    useUpdateFeatureMutation()

  const isPending = isCreating || isUpdating

  // ✅ Step 1: Initialize form with formOptions (contains defaultValues based on feature)
  const form = useAppForm({
    ...FeatureFormOptions(feature), // Spread formOptions - handles defaultValues transformation
    onSubmit: async ({ formApi, value }: { formApi: AnyFormApi; value: FeatureFormSchema }) => {
      // Transform form data to API format if needed
      const apiData = {
        // ... transform value to API format
      }

      await apiFormValidation(
        () =>
          isEdit && feature
            ? updateFeature({ ...apiData, id: feature.id })
            : createFeature(apiData),
        formApi
      )

      toast.success(isEdit ? 'Feature updated successfully' : 'Feature created successfully')
      onClose()
    },
    validators: {
      onChange: featureFormSchema // Can be defined here or in formOptions
    }
  })

  return (
    <Dialog onOpenChange={onClose} open={isOpen}>
      <DialogContent>
        <DialogHeader>
          <DialogTitle>{isEdit ? 'Edit Feature' : 'Create Feature'}</DialogTitle>
        </DialogHeader>

        {/* ✅ Step 2: Key prop ensures form recreates with fresh defaultValues when feature changes */}
        <form
          className="w-full space-y-5"
          key={feature?.id || 'new'} // CRITICAL: Forces form recreation with updated defaultValues
          onSubmit={(e) => {
            e.preventDefault()
            e.stopPropagation()
            form.handleSubmit()
          }}
        >
          <form.AppField name="name">
            {(field) => <field.Input placeholder="Name" />}
          </form.AppField>

          <form.AppField name="email">
            {(field) => <field.Input placeholder="Email" type="email" />}
          </form.AppField>

          <DialogFooter>
            <Button type="button" variant="outline" onClick={onClose}>
              <X className="h-4 w-4" />
              Cancel
            </Button>
            <form.AppForm>
              <form.SubmitButton disabled={isPending}>
                {isEdit ? (
                  <>
                    <Save className="h-4 w-4" />
                    {isPending ? 'Updating...' : 'Update'}
                  </>
                ) : (
                  <>
                    {isPending ? 'Creating...' : 'Create'}
                  </>
                )}
              </form.SubmitButton>
            </form.AppForm>
          </DialogFooter>
        </form>
      </DialogContent>
    </Dialog>
  )
}
```

**Key Checklist for Modal Forms:**

1. ✅ Use `formOptions` for initial form setup - spread into `useAppForm`
2. ✅ Use `key` prop on form element to force recreation when data changes
3. ✅ Key should be entity ID or 'new' for create mode
4. ✅ Handle all data transformations in formOptions (not in component)
5. ✅ Use `apiFormValidation` for error handling
6. ✅ Never use `useEffect` to sync form values - update defaultValues through form recreation instead

