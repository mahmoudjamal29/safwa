        hidden?: (row: Feature) => boolean
        onClick: (row: Feature) => void
      }
    } = {}

    // ✅ DO: Only add actions if permission exists, with hidden property
    if (permissions.view) {
      availableActions.view = {
        hidden: () => !permissions.view,
        onClick: () => setRowAction({ row, variant: 'view' })
      }
