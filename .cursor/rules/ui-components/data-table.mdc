**✅ CORRECT: Use onDelete callback for mock/local state updates**

```typescript
'use client'

import React, { useState } from 'react'
import { toast } from 'sonner'

import { useRowActions } from '@/hooks/use-row-actions'
import { FAQ, MOCK_FAQS } from './types'

export const FaqsTable: React.FC = () => {
  const [faqs, setFaqs] = useState<FAQ[]>(MOCK_FAQS)

  // ✅ CORRECT: Use onDelete callback without deleteDialogConfig for mock data
  const { permissions, setRowAction } = useRowActions<FAQ>({
    onDelete: (faq) => {
      // Mock delete - update local state
      setFaqs((prev) => prev.filter((f) => f.id !== faq.id))
      toast.success(`FAQ "${faq.question}" deleted successfully`)
    },
    permissions: {
      delete: true,
      update: true
    },
    redirectOnUpdate: (faq) => `/faq/${faq.id}/edit`
  })

  // ... rest of component
}
```

### Anti-Patterns: Manual Row Action Management

**❌ DON'T: Manual setRowAction callback when useRowActions can be used**

```typescript
// ❌ WRONG: Manual setRowAction callback
const router = useRouter()
const [deleteItem, setDeleteItem] = useState<Feature | null>(null)
const [deleteOpen, setDeleteOpen] = useState(false)

const setRowAction = useCallback(
  (rowAction?: DataTableRowAction<Feature> | null) => {
    if (!rowAction) return
    const { row, variant } = rowAction
    const item = row.original
    switch (variant) {
      case 'delete':
        setDeleteItem(item)
        setDeleteOpen(true)
        break
      case 'update':
        router.push(`/features/${item.id}/edit`)
        break
      // ... other cases
    }
  },
  [router]
)
```

**✅ DO: Use useRowActions hook**

```typescript
// Constants moved outside component to avoid recreation
const PERMISSIONS_CONFIG = {
  delete: PERMISSIONS.FEATURES_DESTROY,
  update: PERMISSIONS.FEATURES_UPDATE,
  view: PERMISSIONS.FEATURES_SHOW
} as const

// ✅ CORRECT: Use useRowActions hook
const { deleteDialog, permissions, setRowAction } = useRowActions<Feature>({
  deleteMutationOptions: deleteFeatureMutationOptions,
  deleteDialogConfig: {
    title: 'Delete Feature',
    description: 'Are you sure you want to delete this feature?',
    getItemName: (feature) => feature.name
  },
  permissions: PERMISSIONS_CONFIG,
  redirectOnUpdate: (feature) => `/features/${feature.id}/edit`,
  redirectOnView: (feature) => `/features/${feature.id}`
})
```

**❌ DON'T: Manual delete state management**

```typescript
// ❌ WRONG: Manual useState for delete state
const [deleteItem, setDeleteItem] = useState<Feature | null>(null)
const [deleteOpen, setDeleteOpen] = useState(false)

// ❌ WRONG: Manual DeleteConfirmationDialog rendering
{deleteItem && (
  <DeleteConfirmationDialog
    isOpen={deleteOpen}
    mutationFnParam={deleteItem.id}
    mutationOptions={deleteFeatureMutationOptions}
    onClose={() => setDeleteItem(null)}
    onOpenChange={setDeleteOpen}
    title="Delete Feature"
  />
)}
```

**✅ DO: Use deleteDialog from useRowActions hook**

```typescript
// ✅ CORRECT: Delete dialog comes from hook
const { deleteDialog } = useRowActions<Feature>({
  deleteMutationOptions: deleteFeatureMutationOptions,
  deleteDialogConfig: { ... }
})

// ✅ CORRECT: Pass deleteDialog as prop to DataTable
<DataTable deleteDialog={deleteDialog} ... />
```

**❌ DON'T: Manual permission checking in table components**

```typescript
// ❌ WRONG: Manual usePermissions hook in table component
const { hasPermission } = usePermissions()

const columns = useFeatureColumns({
  permissions: {
    delete: hasPermission(PERMISSIONS.FEATURES_DESTROY),
    edit: hasPermission(PERMISSIONS.FEATURES_UPDATE),
    view: hasPermission(PERMISSIONS.FEATURES_SHOW)
  },
  setRowAction
})
```

**✅ DO: Use permissions from useRowActions hook**

```typescript
// Constants moved outside component to avoid recreation
const PERMISSIONS_CONFIG = {
  delete: PERMISSIONS.FEATURES_DESTROY,
  update: PERMISSIONS.FEATURES_UPDATE,
  view: PERMISSIONS.FEATURES_SHOW
} as const

// ✅ CORRECT: Permissions come from hook
const { permissions } = useRowActions<Feature>({
  permissions: PERMISSIONS_CONFIG
})

const columns = useFeatureColumns({
  permissions,
  setRowAction
})
```

### Row Actions in Columns

**⚠️ CRITICAL: Always check permissions before adding actions. Actions should NOT be visible if the user doesn't have permission.**

```typescript
{
  cell: ({ row }) => {
    // Define available actions based on permissions
    const availableActions: {
      delete?: {
        hidden?: (row: Feature) => boolean
        onClick: (row: Feature) => void
