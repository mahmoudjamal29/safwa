}
```

### Status Columns

```typescript
// ✅ CORRECT: Use Column.Chip with translations
{
  accessorKey: 'status',
  cell: ({ row }) => {
    const status = row.original.status
    const isActive = status === 1
    return (
      <Column.Chip
        label={isActive ? tStatus('1') : tStatus('0')}
        variant={isActive ? 'success' : 'destructive'}
      />
    )
  },
  enableColumnFilter: true,
  enableHiding: true,
  header: ({ column }) => (
    <DataTableColumnHeader column={column} title="Status" />
  ),
  id: 'status',
  size: 100
}

// ❌ WRONG: Direct Chip import or hard-coded labels
cell: ({ row }) => {
  return <Chip variant="success">{status === 1 ? 'Active' : 'Inactive'}</Chip>
}
```

