### Accept/Reject Actions Pattern

**Accept and Reject actions** are specialized row actions designed for approval workflows (e.g., request approvals, status changes). They provide built-in loading states, status indicators, and dynamic styling based on the current state of each row.

#### Key Features

- **Loading States**: Shows spinner while mutation is in progress
- **Status Indicators**: Visual feedback for approved/rejected states
- **Dynamic Tooltips**: Tooltip text changes based on current state ("Approve", "Approving...", "Approved", "Reject", "Rejecting...", "Rejected")
- **Conditional Styling**: Opacity and border colors change based on approval status
- **Permission Support**: Can be conditionally shown/hidden based on permissions

#### Accept/Reject Action Properties

When using `createRowActions`, accept and reject actions support these special properties:

```typescript
accept?: {
  disabled?: (row: TData) => boolean        // Disable action for specific rows
  getStatus?: (row: TData) => number | string | undefined  // Get status value from row
  isApproved?: (row: TData) => boolean      // Check if row is approved
  isLoading?: (row: TData) => boolean        // Check if mutation is in progress
  isRejected?: (row: TData) => boolean      // Check if row is rejected
  onClick: (row: TData) => void             // Handler function
}

reject?: {
  disabled?: (row: TData) => boolean        // Disable action for specific rows
  getStatus?: (row: TData) => number | string | undefined  // Get status value from row
  isApproved?: (row: TData) => boolean      // Check if row is approved
  isLoading?: (row: TData) => boolean        // Check if mutation is in progress
  isRejected?: (row: TData) => boolean      // Check if row is rejected
  onClick: (row: TData) => void             // Handler function
}
```

#### Complete Example: Accept/Reject Actions

**1. Define mutations with loading states:**

```typescript
'use client'

import { useMutation } from '@tanstack/react-query'
import { useCallback } from 'react'
import { fetcher } from '@/lib/fetcher'
import { ENDPOINTS } from '@/query-client'

export const useAcceptRequestMutation = () => {
  return useMutation<API<unknown>, AxiosError<API>, number | string>({
    meta: {
      invalidatesQuery: [['requests']]
    },
    mutationFn: async (requestId) =>
      fetcher(ENDPOINTS.REQUESTS.ACCEPT(requestId), {
        auth: true,
        method: 'PUT'
      })
  })
}

export const useRejectRequestMutation = () => {
  return useMutation<API<unknown>, AxiosError<API>, number | string>({
    meta: {
      invalidatesQuery: [['requests']]
    },
    mutationFn: async (requestId) =>
      fetcher(ENDPOINTS.REQUESTS.REJECT(requestId), {
        auth: true,
        method: 'PUT'
      })
  })
}
```

**2. Use useRowActions hook with custom callbacks:**

**⚠️ NOTE: With `useRowActions`, you don't need a separate custom hook. The hook handles all row actions internally. For custom mutations like accept/reject, use the `onAccept` and `onReject` callbacks.**

```typescript
'use client'

import { useState, useCallback } from 'react'
import { useMutation } from '@tanstack/react-query'
import { useRowActions } from '@/hooks/use-row-actions'
import {
  acceptRequestMutationOptions,
  rejectRequestMutationOptions
} from '@/query/requests'
import { Request } from '@/query/requests/requests-types'
import { PERMISSIONS } from '@/lib/auth/permissions'

// Constants moved outside component to avoid recreation
const PERMISSIONS_CONFIG = {
  accept: PERMISSIONS.REQUESTS_ACCEPT,
  reject: PERMISSIONS.REQUESTS_REJECT,
  view: PERMISSIONS.REQUESTS_SHOW
} as const

export function RequestsTable() {
  // Track loading state per request ID for accept/reject actions
  const [acceptingIds, setAcceptingIds] = useState<Set<number | string>>(
    new Set()
  )
  const [rejectingIds, setRejectingIds] = useState<Set<number | string>>(
    new Set()
  )

  const acceptMutation = useMutation(acceptRequestMutationOptions)
  const rejectMutation = useMutation(rejectRequestMutationOptions)

  const { deleteDialog, permissions, setRowAction } = useRowActions<Request>({
    onAccept: async (request) => {
      setAcceptingIds((prev) => new Set(prev).add(request.id))
      try {
        await acceptMutation.mutateAsync(request.id)
      } finally {
        setAcceptingIds((prev) => {
          const next = new Set(prev)
          next.delete(request.id)
          return next
        })
      }
    },
    onReject: async (request) => {
      setRejectingIds((prev) => new Set(prev).add(request.id))
      try {
        await rejectMutation.mutateAsync(request.id)
      } finally {
        setRejectingIds((prev) => {
          const next = new Set(prev)
          next.delete(request.id)
          return next
        })
      }
    },
    permissions: PERMISSIONS_CONFIG,
    redirectOnView: (request) => `/requests/${request.id}`
  })

  // Helper functions to check loading state per request
  const isAcceptingRequest = useCallback(
    (requestId: number | string) => acceptingIds.has(requestId),
    [acceptingIds]
  )

  const isRejectingRequest = useCallback(
    (requestId: number | string) => rejectingIds.has(requestId),
    [rejectingIds]
  )

  // Use permissions and setRowAction from hook
  // ...
}
```

**3. Use in columns with status checks:**

```typescript
'use client'

import { useMemo } from 'react'
import { ColumnDef } from '@tanstack/react-table'
import { createRowActions, DataTableRowActions } from '@/components/data-table/data-table-row-actions'
import { Request } from '@/query/requests/requests-types'
import { DataTableRowAction } from '@/types/data-table'

type RequestColumnsProps = {
  isAccepting: (requestId: number | string) => boolean
  isRejecting: (requestId: number | string) => boolean
  permissions: {
    accept?: boolean
    reject?: boolean
    view?: boolean
  }
  setRowAction: (rowAction?: DataTableRowAction<Request> | null) => void
}

export function useRequestColumns({
  isAccepting,
  isRejecting,
  permissions = {
    accept: true,
    reject: true,
    view: true
  },
  setRowAction
}: RequestColumnsProps): ColumnDef<Request>[] {
  return useMemo(
    () => [
      // ... other columns
      {
        cell: ({ row }) => {
          const request = row.original

          // Define available actions based on permissions
          const availableActions: {
            accept?: {
              disabled?: (row: Request) => boolean
              isApproved?: (row: Request) => boolean
              isLoading?: (row: Request) => boolean
              isRejected?: (row: Request) => boolean
              onClick: (row: Request) => void
            }
            reject?: {
              disabled?: (row: Request) => boolean
              isApproved?: (row: Request) => boolean
              isLoading?: (row: Request) => boolean
              isRejected?: (row: Request) => boolean
              onClick: (row: Request) => void
            }
            view?: (row: Request) => void
          } = {}

          // ✅ DO: Only add actions if permission exists
          if (permissions.view) {
            availableActions.view = {
              hidden: () => !permissions.view,
              onClick: () => setRowAction({ row, variant: 'view' })
            }
          }

          if (permissions.accept) {
            availableActions.accept = {
              disabled: (row) => row.status === RequestStatusEnum.APPROVED || row.status === RequestStatusEnum.REJECTED,
              hidden: () => !permissions.accept,
              isApproved: (row) => row.status === RequestStatusEnum.APPROVED,
              isLoading: (row) => isAccepting(row.id),
              isRejected: (row) => row.status === RequestStatusEnum.REJECTED,
              onClick: (row) => setRowAction({ row, variant: 'accept' })
            }
          }

          if (permissions.reject) {
            availableActions.reject = {
              disabled: (row) => row.status === RequestStatusEnum.APPROVED || row.status === RequestStatusEnum.REJECTED,
              hidden: () => !permissions.reject,
              isApproved: (row) => row.status === RequestStatusEnum.APPROVED,
              isLoading: (row) => isRejecting(row.id),
              isRejected: (row) => row.status === RequestStatusEnum.REJECTED,
              onClick: (row) => setRowAction({ row, variant: 'reject' })
            }
          }

          if (permissions.view) {
            availableActions.view = {
              hidden: () => !permissions.view,
              onClick: () => setRowAction({ row, variant: 'view' })
            }
          }

          const actions = createRowActions(availableActions)

          return <DataTableRowActions actions={actions} row={row} />
        },
        enableHiding: false,
        header: () => (
          <div className="text-center font-semibold">
            Actions
          </div>
        ),
        id: 'actions',
        size: 150
      }
    ],
    [isAccepting, isRejecting, permissions, setRowAction]
  )
}
```

