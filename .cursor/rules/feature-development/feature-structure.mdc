### 5. Table Components (`_{feature}/tables/{resource}-table.tsx`)

```tsx
'use client'

import React from 'react'
import { useQuery } from '@tanstack/react-query'
// When translations are requested, add: import { useTranslations } from 'next-intl'

import { DataTable, DataTableToolbar } from '@/components/data-table'
import { useDataTable } from '@/hooks/use-data-table'
import { useRowActions } from '@/hooks/use-row-actions'
import { cn } from '@/utils'

import { use{Resource}Columns } from '@/app/(app)/{feature}/_{feature}/columns/{resource}-columns'
import { {Parent}TablesProps } from '@/app/(app)/{feature}/_{feature}/types/tabs-types'
import { PERMISSIONS } from '@/lib/auth/permissions'
import { get{Resource}By{Parent}IdQuery, delete{Resource}MutationOptions } from '@/query/{feature}'

export const {Resource}Table: React.FC<{Parent}TablesProps & { className?: string }> = ({
  {parent}Id,
  {parent}Name,
  className
}) => {
  // When translations are requested, add: const tDeleteDialog = useTranslations('{feature}.deleteDialog')

  const { data: {resources}, isLoading, isError, error, refetch } = useQuery(
    get{Resource}By{Parent}IdQuery({parent}Id)
  )

  const { deleteDialog, permissions, setRowAction } = useRowActions<{Resource}>({
    deleteDialogConfig: {
      description: 'Are you sure you want to delete this {resource}?',
      getItemName: ({resource}) => {resource}.name,
      title: 'Delete {Resource}'
    },
    deleteMutationOptions: delete{Resource}MutationOptions,
    permissions: {
      delete: PERMISSIONS.{FEATURE}_DESTROY,
      update: PERMISSIONS.{FEATURE}_UPDATE
    },
    redirectOnUpdate: ({resource}) =>
      `/{feature}/${decodeURIComponent({parent}Name.replaceAll(' ', '-').toLowerCase())}-${{parent}Id}/edit-{resource}/${resource}.id`
  })

  const columns = use{Resource}Columns({
    permissions,
    setRowAction
  })

  const { table } = useDataTable({
    clearOnDefault: true,
    columns,
    data: {resources}?.data?.data || [],
    getRowId: (originalRow) => `${originalRow.id}`,
    initialState: {
      columnPinning: { right: ['actions'] },
      pagination: {
        pageIndex: {resources}?.data?.pagination?.current_page || 0,
        pageSize: {resources}?.data?.pagination?.per_page || 15
      },
      sorting: [{ desc: true, id: 'id' }]
    },
    pageCount: {resources}?.data?.pagination?.last_page || 0,
    rowCount: {resources}?.data?.pagination?.total || 0
  })

  return (
    <main className={cn('relative', className)}>
      <DataTable
        deleteDialog={deleteDialog}
        error={error}
        isError={isError}
        isLoading={isLoading}
        refetch={refetch}
        toolbar={
          <DataTableToolbar
            createButtonHref={`/{feature}/${decodeURIComponent({parent}Name.replaceAll(' ', '-').toLowerCase())}-${{parent}Id}/add-{resource}`}
            filters={[
              {
                key: 'status',
                label: 'Status',
                options: [
                  { key: 'active', label: 'Active', value: '1' },
                  { key: 'inactive', label: 'Inactive', value: '0' }
                ],
                placeholder: 'Select status'
              }
            ]}
            permissions={{
              create: PERMISSIONS.{FEATURE}_CREATE
            }}
            searchPlaceholder="Search {resources}"
            table={table}
          />
        }
        table={table}
      />
      {/* When translations are requested, replace hard-coded strings in deleteDialogConfig:
          deleteDialogConfig: {
            description: tDeleteDialog('description'),
            title: tDeleteDialog('title')
          }
      */}
    </main>
  )
}
```

### 6. Hooks (`_{feature}/hooks/use-{feature}-params.ts`)

**⚠️ CRITICAL: ALWAYS create query parameters in a custom params hook. DO NOT create query params objects inline in components, tabs, or pages.**

**⚠️ CRITICAL: File naming**: Hook files MUST be named `use-{feature}-params.ts` (e.g., `use-centers-params.ts`, `use-tenants-params.ts`).

**⚠️ CRITICAL: Feature params hooks MUST use `useStandardParams` from `@/hooks/use-standard-params`** as it's shared across all features.

**For tabs and nested components within a feature**: Use the main feature's params hook (e.g., `use{Feature}Params()`) instead of creating separate query state management. If the feature has a main params hook, tabs and components within that feature should import and use it rather than managing query params independently with `useQueryState` or `useQueryStates`.

```tsx
import { parseAsStringEnum, useQueryState } from 'nuqs'
import { useStandardParams } from '@/hooks/use-standard-params'

export const use{Feature}Params = () => {
  const { standardParams, setStandardParams } = useStandardParams()

  // Feature-specific filters (not in useStandardParams)
  const [status, setStatus] = useQueryState(
    'status',
    parseAsStringEnum(['0', '1', '']).withDefault('')
  )
  const [type, setType] = useQueryState(
    'type',
    parseAsStringEnum(['0', '1', '2', '']).withDefault('')
  )

  // standardQueryParams MUST only include page, per_page, and search
  const standardQueryParams = {
    page: standardParams.page,
    per_page: standardParams.per_page,
    search: standardParams.search
  }

  return {
    ...standardParams, // Return standardParams as-is (not destructured)
    setStandardParams,
    setStatus,
    setType,
    standardQueryParams,
    status,
    type
  }
}
```

```tsx
// _{feature}/hooks/index.ts
export * from './use-{feature}-params'
```

**Example of WRONG pattern** (DO NOT DO THIS):

```tsx
// ❌ DON'T: Managing query params directly in tabs/components
export function SomeTab() {
  const [search] = useQueryState('search', parseAsString.withDefault(''))
  const [type] = useQueryState('type', parseAsInteger)
  const [status] = useQueryState('status', parseAsInteger)
  const [page] = useQueryState('page', parseAsInteger.withDefault(1))
  const [perPage] = useQueryState('per_page', parseAsInteger.withDefault(15))

  const queryParams = useMemo(
    () => ({
      page,
      per_page: perPage,
      ...(search && { search }),
      ...(type && { type }),
      ...(status && { status })
    }),
    [search, type, status, page, perPage]
  )
  // ...
}
```

**Example of CORRECT pattern**:

```tsx
// ✅ DO: Use the main feature params hook
import { use{Feature}Params } from '@/app/(app)/{feature}/_{feature}/hooks'

export function SomeTab() {
  const { standardQueryParams, status, type } = use{Feature}Params()

  const queryParams = useMemo(
    () => ({
      ...standardQueryParams,
      ...(type && { type }),
      ...(status && { status })
    }),
    [standardQueryParams, status, type]
  )
  // ...
}
```

