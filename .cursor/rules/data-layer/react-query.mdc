## Query Options Pattern

### Import Pattern

```typescript
import { queryOptions } from '@tanstack/react-query'
import { AxiosError } from 'axios'
import { fetcher } from '@/lib/fetcher'
import { ENDPOINTS } from '@/query-client'
import { {ResourceType} } from './{feature}-types'
```

### List Query with Pagination

**✅ ALWAYS use `select` to transform the response** - Extract `data.data` and provide `paginationFallback` for non-paginated responses:

```typescript
import { paginationFallback } from '@/lib/fetcher/utils'

export const getAll{Resource}Query = (params: unknown) =>
  queryOptions<
    API<PaginatedResponse<{Resource}[]>>,
    AxiosError<API>,
    PaginatedResponse<{Resource}[]>
  >({
    queryFn: () =>
      fetcher(ENDPOINTS.{FEATURE}.GET_ALL, {
        auth: true,
        params
      }),
    queryKey: ['{resource-name}', params],
    select: (data) => data.data ?? { data: [], pagination: paginationFallback }
  })
```

**In components**, use the transformed data directly (no need for `useMemo` or manual extraction):

```typescript
// ✅ CORRECT: Query has select, so data is already PaginatedResponse<Resource[]>
const { data: {resources}Data } = useQuery(getAll{Resource}Query(params))

// Data is already transformed by select - access directly
const items = {resources}Data?.data ?? []
const pagination = {resources}Data?.pagination
```

**⚠️ CRITICAL: Variable Naming**

- **✅ DO**: Use `*Data` suffix when query has `select` (e.g., `centersData`, `{resources}Data`)
- **❌ DON'T**: Use `*Response` suffix when query has `select` - this implies raw API structure
- **✅ DO**: Name the data directly in the destructuring (e.g., `data: floorsData`) instead of renaming afterward
- **❌ DON'T**: Destructure as `data: floorsResponse` and then assign `const floorsData = floorsResponse` - name it correctly in the destructuring

**Example:**

```typescript
// ✅ CORRECT: Name data directly in destructuring
const {
  data: floorsData,
  error,
  isLoading
} = useQuery(getAllFloorsQuery(centerId, params))

// ❌ WRONG: Don't rename afterward
const {
  data: floorsResponse, // ❌ Wrong name
  error,
  isLoading
} = useQuery(getAllFloorsQuery(centerId, params))

const floorsData = floorsResponse // ❌ Unnecessary renaming
```

### Single Resource Query

**✅ ALWAYS use `select` for single resource queries** - Extract `data.data` and provide `undefined` fallback:

```typescript
export const get{Resource}ByIdQuery = (id?: number | string) =>
  queryOptions<API<{Resource}ById>, AxiosError<API>, {Resource}ById | undefined>({
    queryFn: () =>
      fetcher(ENDPOINTS.{FEATURE}.GET_BY_ID(id!), {
        auth: true,
        enabled: !!id
      }),
    queryKey: ['{resource-name}', id],
    select: (data) => data.data ?? undefined
  })
```

**In components**, use the transformed data directly:

```typescript
// ✅ CORRECT: Query has select, so data is already {Resource}ById | undefined
const { data: {resource} } = useQuery(get{Resource}ByIdQuery(id))

// Data is already transformed by select - {resource} is {Resource}ById | undefined
if (!{resource}) {
  return <NotFound />
}
```

### Nested Resource Query

**✅ ALWAYS use `select` for paginated nested resources**:

```typescript
import { paginationFallback } from '@/lib/fetcher/utils'

export const get{NestedResource}By{Parent}IdQuery = (
  {parent}Id: number | string,
  params?: unknown
) =>
  queryOptions<
    API<PaginatedResponse<{NestedResource}[]>>,
    AxiosError<API>,
    PaginatedResponse<{NestedResource}[]>
  >({
    queryFn: () =>
      fetcher(ENDPOINTS.{FEATURE}.GET_{NESTED}_BY_{PARENT}({parent}Id), {
        auth: true,
        params
      }),
    queryKey: ['{parent}-{nested}', {parent}Id, params],
    select: (data) => data.data ?? { data: [], pagination: paginationFallback }
  })
```

### Infinite Query Options

**✅ ALWAYS use `infiniteQueryOptions` with 5 type parameters** for infinite/paginated queries:

**Import Pattern:**

```typescript
import {
  InfiniteData,
  infiniteQueryOptions,
  queryOptions
} from '@tanstack/react-query'
import { AxiosError } from 'axios'

import { fetcher } from '@/lib/fetcher'
import { ENDPOINTS } from '@/query-client'
import { QueryKey } from '@/query-client/query'

import type { {Resource} } from './{feature}-types'
```

**Infinite Query Pattern:**

```typescript
export const getAll{Resource}InfiniteQuery = (
  params?: Omit<{Resource}ListParams, 'page' | 'per_page'> = {}
) =>
  infiniteQueryOptions<
    API<PaginatedResponse<{Resource}[]>>,
    AxiosError<API>,
    InfiniteData<API<PaginatedResponse<{Resource}[]>>>,
    QueryKey,
    number
  >({
    queryFn: ({ pageParam }) =>
      fetcher(ENDPOINTS.{FEATURE}.GET_ALL, {
        auth: true,
        params: {
          ...params,
          page: pageParam as number,
          per_page: 20
        }
      }),
    initialPageParam: 1,
    getNextPageParam: (lastPage) => {
      const pagination = lastPage.data?.pagination
      if (!pagination) return undefined
      if (pagination.current_page < pagination.last_page) {
        return pagination.current_page + 1
      }
      return undefined
    },
    queryKey: ['{resource-name}', 'infinite', params]
  })
```

**Key Requirements:**

1. **Type Parameters** - MUST include all 5 type parameters:
   - `API<PaginatedResponse<{Resource}[]>>` - Response type
   - `AxiosError<API>` - Error type
   - `InfiniteData<API<PaginatedResponse<{Resource}[]>>>` - Infinite data wrapper
   - `QueryKey` - Query key type (import from `@/query-client/query`)
   - `number` - Page parameter type

2. **Function Parameters** - Omit `page` and `per_page` from params type:

   ```typescript
   params?: Omit<{Resource}ListParams, 'page' | 'per_page'>
   ```

3. **Query Function** - Use `pageParam` from query function parameter:

   ```typescript
   queryFn: ({ pageParam }) =>
     fetcher(ENDPOINTS.{FEATURE}.GET_ALL, {
       auth: true,
       params: {
         ...params,
         page: pageParam as number,
         per_page: 20 // Fixed page size
       }
     })
   ```

4. **Initial Page Param** - Always set to `1`:

   ```typescript
   initialPageParam: 1
   ```

5. **Get Next Page Param** - Extract pagination from `lastPage.data?.pagination`:

   ```typescript
   getNextPageParam: (lastPage) => {
     const pagination = lastPage.data?.pagination
     if (!pagination) return undefined
     if (pagination.current_page < pagination.last_page) {
       return pagination.current_page + 1
     }
     return undefined
   }
   ```

6. **Query Key** - Include `'infinite'` segment for cache separation:
   ```typescript
   queryKey: ['{resource-name}', 'infinite', params]
   ```

**Reference Implementation:**

```39:68:query/doors/doors-query.ts
export const getAllDoorsInfiniteQuery = (
