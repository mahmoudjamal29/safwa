// query/tenants/tenants-query.ts
export const getAllTenantsQuery = (params: unknown) =>
  queryOptions<API<PaginatedResponse<Tenant[]>>, AxiosError<API>>({
    queryFn: () =>
      fetcher(ENDPOINTS.TENANTS.GET_ALL, {
        auth: true,
        params
      }),
    queryKey: ['tenants', params]
  })

