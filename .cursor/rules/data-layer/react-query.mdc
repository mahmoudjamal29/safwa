### Query with Select Transformation

**For single resources** (non-paginated):

```typescript
export const get{Resource}ByIdQuery = (id: number | string) =>
  queryOptions<API<{Resource}>, AxiosError<API>, {Resource} | undefined>({
    queryFn: () =>
      fetcher(ENDPOINTS.{FEATURE}.GET_BY_ID(id), {
        auth: true,
        enabled: !!id
      }),
    queryKey: ['{resource-name}', id],
    select: (data) => data.data ?? undefined
  })
```

**For paginated responses**, **ALWAYS use `select`** to extract `data.data` and provide `paginationFallback`:

```typescript
import { paginationFallback } from '@/lib/fetcher/utils'

export const get{Resource}By{Parent}IdQuery = (
  {parent}Id?: number | string,
  params?: unknown
) =>
  queryOptions<
    API<PaginatedResponse<{Resource}[]>>,
    AxiosError<API>,
    PaginatedResponse<{Resource}[]>
  >({
    enabled: !!{parent}Id,
    queryFn: () =>
      fetcher(ENDPOINTS.{FEATURE}.GET_BY_{PARENT}({parent}Id!), {
        auth: true,
        params
      }),
    queryKey: ['{resource-name}', {parent}Id, params],
    select: (data) => data.data ?? { data: [], pagination: paginationFallback }
  })
```

**⚠️ CRITICAL: Component Usage Pattern**

**✅ CORRECT: Access transformed data directly after `select`:**

```typescript
// Query has select: (data) => data.data ?? { data: [], pagination: paginationFallback }
const { data: centersData } = useQuery(getAllCentersQuery())
// centersData is PaginatedResponse<Center[]> (already transformed by select)
const centers = centersData?.data ?? [] // ✅ CORRECT: Access .data for the array
const pagination = centersData?.pagination
```

**❌ WRONG: Accessing raw API response structure:**

```typescript
// ❌ DON'T: Treating data as API<PaginatedResponse<Center[]>>
const { data: centersResponse } = useQuery(getAllCentersQuery())
const centers = centersResponse?.data ?? [] // ❌ WRONG: centersResponse is already PaginatedResponse, not API
```

**Important**:

- **ALWAYS use `select` in query options** - Transform `API<T>` to `T` (or `API<PaginatedResponse<T[]>>` to `PaginatedResponse<T[]>`)
- **DO NOT** use `useMemo` in components to extract data - the `select` function already handles transformation
- **DO NOT** access `response?.data?.data` - after `select`, `data` is already transformed, access `response?.data` directly for arrays
- **DO NOT** name variables `*Response` when query has `select` - use `*Data` instead since it's already transformed
- **ALWAYS** provide `paginationFallback` for paginated queries to ensure consistent structure
- **For single resources with `select`**: `data` is the resource directly (e.g., `const { data: center } = useQuery(...)` where `center` is `Center | undefined`)

### Response Type Expectations

- All responses use `API<T>` (`data`, `errors`, `message`, `statusCode`, `success`).
- Use `API<PaginatedResponse<T[]>>` for lists; `PaginatedResponse` supplies pagination metadata.
- Use `API<{Resource}>` or `API<{Resource}ById>` for detail views.

### Naming Conventions

- `getAll{Resource}Query` for paginated lists.
- `get{Resource}ByIdQuery` for detail views.
- `get{NestedResource}By{Parent}IdQuery` for nested data.
- `get{Resource}By{Param}Query` for filtered lookups.

### Query Options Extras

- Use `enabled` for conditional fetches.
- Include filter params in the `queryKey`.
- Use `select` for data shaping; do not mutate the original response.

## Mutation Pattern

**⚠️ CRITICAL: ALWAYS export `mutationOptions` from query files, NOT `useMutation` hooks.**

**Exception**: Hooks that use other hooks (e.g., `useRouter`, `useAdminStore`, `useTranslations`) may remain as hooks with a concise comment explaining why (e.g., `// Uses useRouter - must remain as hook`).

### Import Pattern

```typescript
import { mutationOptions } from '@tanstack/react-query'
import { AxiosError } from 'axios'
import { fetcher } from '@/lib/fetcher'
import { ENDPOINTS } from '@/query-client'
```

### Create Mutation

```typescript
export const create{Resource}MutationOptions = mutationOptions<
  API,
  AxiosError<API>,
  Create{Resource}Input
>({
  meta: {
    invalidatesQuery: [['{resource-name}']]
    // ⚠️ DO NOT add successMessage/errorMessage - messages are handled by backend
  },
  mutationFn: async (data) =>
    fetcher(ENDPOINTS.{FEATURE}.CREATE, {
      auth: true,
      body: data,
      method: 'POST'
    })
})
```

### Update / Delete Mutations

```typescript
export const update{Resource}MutationOptions = mutationOptions<
  API,
  AxiosError<API>,
  Update{Resource}Input & { id?: number | string }
>({
  meta: {
    invalidatesQuery: [['{resource-name}']]
  },
  mutationFn: async (data) =>
    fetcher(ENDPOINTS.{FEATURE}.UPDATE(data.id!), {
      auth: true,
      body: data,
      method: 'PUT'
    })
})

export const delete{Resource}MutationOptions = mutationOptions<
  API,
  AxiosError<API>,
  number | string
>({
  meta: {
    invalidatesQuery: [['{resource-name}']]
  },
  mutationFn: async (id) =>
    fetcher(ENDPOINTS.{FEATURE}.DELETE(id), {
      auth: true,
      method: 'DELETE'
    })
})
```

### Exception: Hooks That Use Other Hooks

**When a mutation needs to use hooks (e.g., `useRouter`, `useAdminStore`, `useTranslations`), it may remain as a hook:**

```typescript
import { mutationOptions, useMutation } from '@tanstack/react-query'
import { useRouter } from 'next/navigation'

export const create{Resource}MutationOptions = mutationOptions<...>({...})

// ⚠️ EXCEPTION: This hook uses useRouter - must remain as hook
export const useCreate{Resource}Mutation = () => {
  const router = useRouter()
  return useMutation({
    ...create{Resource}MutationOptions,
    onSuccess: () => {
      router.push('/{feature}')
    }
  })
}
```

### Mutation Meta Guidelines

- `meta.invalidatesQuery` supports multiple entries for list/detail caches.
- **⚠️ DO NOT add `successMessage`/`errorMessage` in mutation meta** - Messages and translations are handled by the backend. The `MutationCache` will automatically display the `message` field from the API response (`data.message` for success, `error.response?.data.message` for errors).
- Set `toastOnError`/`toastOnSuccess` to `false` when UI handles notifications manually.

### Response Typing

- Prefer `API<unknown>` unless the mutation returns typed payloads.
- Use `API<{Resource}>`, `API<void>`, or `API<undefined>` when API responses are predictable.

### Reusable Mutation Options for Client Components

**When creating mutations for reusable client components** (e.g., `HeaderActions`, toggle components), use `mutationOptions` helper from `@tanstack/react-query` instead of `useMutation` hooks. This allows passing mutation configuration from server components to client components.

**Pattern**:

1. **Create mutation options in `{feature}-mutations.ts`**:

```typescript
import { mutationOptions } from '@tanstack/react-query'
import { AxiosError } from 'axios'
import { fetcher } from '@/lib/fetcher'
import { ENDPOINTS } from '@/query-client'

export const toggle{Resource}StatusMutationOptions = mutationOptions<
  API,
  AxiosError<API>,
  number | string
>({
  meta: {
    invalidatesQuery: [['{resource-name}']]
  },
  mutationFn: async ({resourceId}) =>
    fetcher(ENDPOINTS.{FEATURE}.PUT_TOGGLE_{RESOURCE}_STATUS({resourceId}!), {
      auth: true,
      enabled: !!{resourceId},
      method: 'PUT'
    })
})
```

2. **Export from query layer** (included in `index.ts`):

```typescript
export * from './{feature}-mutations'
```

3. **Pass from server component to client component**:

**⚠️ NOTE: For both detail and edit pages, use `prefetchQuery` on the server and let client components call `useQuery` directly. Do NOT pass fetched entities as props from the server; pass only identifiers and flags (e.g., `id`, `isEdit`). Reserve `fetchQuery` for server-only contexts like `generateMetadata` where you must synchronously read data.**

```typescript
// app/(app)/{feature}/[{resource_info}]/info/page.tsx (Server Component - Detail Page)
import { dehydrate, HydrationBoundary } from '@tanstack/react-query'
import { getQueryClient } from '@/query-client'
import { get{Resource}ByIdQuery, toggle{Resource}StatusMutationOptions } from '@/query/{feature}'
import { {Resource}Tabs } from '@/app/(app)/{feature}/_{feature}/tabs/{resource}-tabs'

export default async function {Resource}InfoPage({ params }) {
  const id = extractId(params)
  const queryClient = getQueryClient()

  // Pre-fetch data on server with error handling
  try {
    await queryClient.prefetchQuery(get{Resource}ByIdQuery(id))
  } catch (error) {
    console.error(error)
  }

  return (
    <HydrationBoundary state={dehydrate(queryClient)}>
      <{Resource}Tabs {resource}Id={id} />
    </HydrationBoundary>
  )
}
```

```typescript
// app/(app)/{feature}/[{resource_info}]/edit-{resource}/page.tsx (Server Component - Edit Page)
import { dehydrate, HydrationBoundary } from '@tanstack/react-query'
import { getQueryClient } from '@/query-client'
import { get{Resource}ByIdQuery } from '@/query/{feature}'
import { {Resource}Form } from '@/app/(app)/{feature}/_{feature}/forms/{resource}-form'

export default async function {Resource}EditPage({ params }) {
  const id = extractId(params)
  const queryClient = getQueryClient()

  // Pre-fetch data on server with error handling
  try {
    await queryClient.prefetchQuery(get{Resource}ByIdQuery(id))
  } catch (error) {
    console.error(error)
  }

  return (
    <HydrationBoundary state={dehydrate(queryClient)}>
      <{Resource}Form {resource}Id={id} isEdit />
    </HydrationBoundary>
  )
}
```

4. **Client form pattern for edit pages (uses `useQuery`)**:

```typescript
'use client'

import { useQuery } from '@tanstack/react-query'

import { useAppForm } from '@/components/form'
import { get{Resource}ByIdQuery } from '@/query/{feature}'
import {
  create{Resource}Schema,
  {Resource}FormOptions
} from '@/app/(app)/{feature}/_{feature}/form-options/{resource}-form-options'

type {Resource}FormProps = {
  isEdit?: boolean
  {resource}Id?: number | string
}

export const {Resource}Form: React.FC<{Resource}FormProps> = ({
  isEdit = false,
  {resource}Id
}) => {
  const { data: {resource}, isLoading } = useQuery({
    ...get{Resource}ByIdQuery({resource}Id),
    enabled: !!isEdit && !!{resource}Id
  })

  const form = useAppForm({
    ...{Resource}FormOptions({resource}),
    validators: {
      onChange: create{Resource}Schema
    },
    onSubmit: async ({ formApi, value }) => {
      // submit logic
    }
  })

  // ... render form fields with loading state
}
```

**⚠️ MANDATORY: Client Component for Detail Pages - MUST use `useQuery` directly**

```typescript
// app/(app)/{feature}/_{feature}/tabs/{resource}-tabs.tsx (Client Component)
'use client'

import { HeaderActions } from '@/components/custom/header-actions'
import { PageHeader } from '@/components/custom/page-header'
import { useQuery } from '@tanstack/react-query'
import { get{Resource}ByIdQuery, toggle{Resource}StatusMutationOptions } from '@/query/{feature}'

type {Resource}TabsProps = {
  {resource}Id: string | number
}

export const {Resource}Tabs: React.FC<{Resource}TabsProps> = ({ {resource}Id }) => {
  // ✅ CORRECT: Client component MUST use useQuery directly
  // The prefetched data from server is automatically used via HydrationBoundary
  const { data: {resource}, isLoading, isError } = useQuery(get{Resource}ByIdQuery({resource}Id))

  if (!{resource} || isError) {
    return <NotFound title="{Resource} not found" />
  }

  return (
    <>
      <PageHeader title={resource.name}>
        <HeaderActions
          activeToggleMutation={{
            mutationFnParam: {resource}Id,
            mutationOptions: toggle{Resource}StatusMutationOptions
          }}
          editPath={`/{feature}/edit/${resource}Id}`}
          initialStatus={resource.status === 1}
        />
      </PageHeader>
      {/* ... tabs content ... */}
    </>
  )
}
```

4. **Use in client component** (for mutations):

```typescript
// components/custom/header-actions.tsx (Client Component)
'use client'

import { useMutation, UseMutationOptions } from '@tanstack/react-query'
import { AxiosError } from 'axios'

type HeaderActionsProps = {
  activeToggleMutation: {
    mutationFnParam: number | string
    mutationOptions: UseMutationOptions<API, AxiosError<API>, number | string>
  }
  // ... other props
}

export const HeaderActions: React.FC<HeaderActionsProps> = ({
  activeToggleMutation
  // ... other props
}) => {
  const { isPending, mutate: toggleActiveStatus } = useMutation(
    activeToggleMutation.mutationOptions
  )

  const handleToggle = () => {
    toggleActiveStatus(activeToggleMutation.mutationFnParam)
  }

  // ... render UI
}
```

**Benefits**:

- Enables reusable components that accept different mutations
- Allows passing mutations from server to client components
- Maintains type safety and proper invalidation patterns
- Separation of concerns: mutation logic in query layer, UI in components

**When to use**:

- ✅ Creating reusable client components that need mutations (e.g., toggle buttons, action buttons)
- ✅ Passing mutations from server components to client components
- ✅ When the same mutation might be used in multiple contexts
- ✅ **ALL mutations in query files** (except those that use other hooks)

**When NOT to use**:

- ❌ For mutations that use other hooks (e.g., `useRouter`, `useAdminStore`) - these may remain as hooks with concise exception comments

**Reference Implementation**:

- Mutation options: `136:150:query/tenants/tenants-mutations.ts`
- Server component usage: `47:51:app/(app)/tenants/[tenant_info]/info/page.tsx`
- Client component implementation: `21:51:components/custom/header-actions.tsx`

## Type Definitions Pattern

```typescript
// query/{feature}/{feature}-types.ts

export type {Resource} = {
  id: number
  created_at: string | null
  updated_at: string | null
  // ...
}

export type {Resource}ById = {Resource} & {
  translations?: {
    id: number
    locale: 'ar' | 'en'
    name: string
  }[]
}

export type Create{Resource}Input = {
  // form schema fields
}

export type Update{Resource}Input = {
  id?: number | string
  // partial fields
}
```

- Match API field names exactly; use `null` for nullable fields.
- Extend base types for detail views instead of re-declaring overlap.
- Share nested types across modules when practical (import rather than duplicate).

## Fetcher Usage Guidelines

```typescript
fetcher(ENDPOINTS.{FEATURE}.GET_ALL, { auth: true })
fetcher(ENDPOINTS.{FEATURE}.GET_BY_ID(id), { auth: true })
fetcher(ENDPOINTS.{FEATURE}.CREATE, { auth: true, body: data, method: 'POST' })
fetcher(ENDPOINTS.{FEATURE}.GET_BY_ID(id), { auth: true, enabled: !!id })
fetcher(ENDPOINTS.{FEATURE}.GET_ALL, {
  auth: true,
  params: { search, status, type }
})
fetcher(ENDPOINTS.{FEATURE}.{SUB}.GET_BY_{PARENT}(parentId), { auth: true })
```

- Always pass `auth: true` for protected routes.
- Supply `params` for query strings and include them in the `queryKey`.
- Call dynamic endpoint functions (`ENDPOINTS.FEATURE.GET_BY_ID(id)`).

## Error & Success Handling

### Queries

- `useQuery` error is typed as `AxiosError<API>`.
- React Query retry defaults can be overridden per-query.
- Use error boundaries or UI fallbacks for fatal states.

```typescript
const { data, isLoading, error } = useQuery(getAllTenantsQuery(params))

if (error) {
  // error.response?.data contains API payload
}
```

### Mutations

- `MutationCache` automatically produces toasts using meta.
- Invalidate related caches by listing them in `meta.invalidatesQuery`.
- Optional `onSuccess`, `onError`, or `onSettled` callbacks remain available.

```typescript
const { mutate, isPending, error } = useCreateTenantMutation()
// Toasts & invalidation handled automatically
```

## Server Component Patterns

**⚠️⚠️⚠️ CRITICAL: ALL server-side data fetching MUST use `prefetchQuery` with try-catch and HydrationBoundary ⚠️⚠️⚠️**

**🚨 NEVER use `fetchQuery` in main page component - ALWAYS use `prefetchQuery` with `HydrationBoundary`**

**⚠️ MANDATORY: Client/child components MUST use `useQuery` directly - they should NOT access data from server prefetch**

**⚠️ IMPORTANT: Only pre-fetch data that is CRITICAL for initial render. For create pages, avoid blocking prefetches for non-critical data (like dropdown options).**

**⚠️ EXCEPTION: `fetchQuery` is ONLY allowed in `generateMetadata` function - Required for synchronous metadata generation**

### ⚠️⚠️⚠️ CRITICAL: fetchQuery vs prefetchQuery Pattern ⚠️⚠️⚠️

**🚨 NEVER use `fetchQuery` in main page component - ALWAYS use `prefetchQuery` with `HydrationBoundary`**

**❌ WRONG: Using fetchQuery in main page component**

```typescript
// ❌ WRONG: fetchQuery blocks rendering and prevents proper hydration
export default async function DetailPage({ params }) {
  const { id } = await params
  const queryClient = getQueryClient()
  const workspace = await queryClient.fetchQuery(getWorkspaceByIdQuery(id)) // ❌ WRONG

  if (!workspace) {
    return <NotFound title="Workspace not found" />
  }

  return <WorkspaceTabs workspaceId={id} workspace={workspace} /> // ❌ WRONG: Passing data as prop
}
```

**✅ CORRECT: Using prefetchQuery with HydrationBoundary**

```typescript
// ✅ CORRECT: prefetchQuery is non-blocking, allows proper hydration
export default async function DetailPage({ params }) {
  const { id } = await params
  const queryClient = getQueryClient()

  try {
    await queryClient.prefetchQuery(getWorkspaceByIdQuery(id)) // ✅ CORRECT
  } catch (error) {
    console.error(error)
  }

  return (
    <HydrationBoundary state={dehydrate(queryClient)}>
      <WorkspaceTabs workspaceId={id} /> {/* ✅ CORRECT: Only pass ID */}
    </HydrationBoundary>
  )
}
```

**✅ CORRECT: Client component uses useQuery to read prefetched data**

```typescript
'use client'

export const WorkspaceTabs: React.FC<{ workspaceId: number | string }> = ({ workspaceId }) => {
  // ✅ CORRECT: useQuery reads prefetched data from HydrationBoundary
  const { data: workspace, isLoading, isError } = useQuery(getWorkspaceByIdQuery(workspaceId))

  if (!workspace || isError) {
    return <NotFound title="Workspace not found" />
  }

  // Use workspace data here
}
```

**When to use fetchQuery vs prefetchQuery:**

- **✅ DO use `prefetchQuery`** in main page component - Non-blocking, enables proper hydration
- **✅ DO use `fetchQuery`** ONLY in `generateMetadata` - Required for synchronous metadata generation
- **❌ DON'T use `fetchQuery`** in main page component - Blocks rendering, breaks hydration
- **❌ DON'T pass fetched data as props** - Client component must use `useQuery` to read prefetched data via `HydrationBoundary`

### When to Pre-fetch on Server

**✅ DO pre-fetch when:**

- **Detail pages** - Need entity data for page content (e.g., user detail page, tenant detail page)
- **Edit pages** - Need existing data to populate form (e.g., `adminByIdOptions` for edit admin page)
- **Critical data** - Data required for initial render that would cause layout shift if missing

**❌ DON'T pre-fetch when:**

- **Create pages** - No existing data needed, form starts empty
- **Dropdown options** - Can load on client when dropdown is opened (non-blocking)
- **Non-critical data** - Data that can be fetched after initial render

### Server Component with Pre-fetching (Detail Pages)

**✅ CORRECT: Use prefetchQuery with try-catch and HydrationBoundary for detail pages**

```typescript
import { Metadata } from 'next'
import { dehydrate, HydrationBoundary } from '@tanstack/react-query'

import { NotFound } from '@/components/ui/not-found'
import { getQueryClient } from '@/query-client'
import { getUserByIdQuery } from '@/query/users'
import { UserTabs } from '@/app/(Dashboard)/customers/_customers/tabs/user-tabs'

type UserDetailPageProps = {
  params: Promise<{
    userID: string
  }>
}

export async function generateMetadata({
  params
}: UserDetailPageProps): Promise<Metadata> {
  const { userID } = await params
  const queryClient = getQueryClient()
  let user

  try {
    const result = await queryClient.fetchQuery(getUserByIdQuery(userID))
    user = result.data
  } catch (error) {
    console.error(error)
  }

  return {
    description: user?.email || 'View customer user details',
    title: user?.name || 'User Details'
  }
}

export default async function UserDetailPage({ params }: UserDetailPageProps) {
  const { userID } = await params

  if (!userID || isNaN(+userID)) {
    return <NotFound title="User ID is invalid" />
  }

  const queryClient = getQueryClient()

  // Pre-fetch data on server with error handling
  try {
    await queryClient.prefetchQuery(getUserByIdQuery(userID))
  } catch (error) {
    console.error(error)
  }

  // Wrap client component with HydrationBoundary to pass dehydrated state
  return (
    <HydrationBoundary state={dehydrate(queryClient)}>
      <UserTabs userID={userID} />
    </HydrationBoundary>
  )
}
```

**⚠️ MANDATORY: Client Component Pattern - MUST use `useQuery` directly**

```typescript
'use client'

import { useQuery } from '@tanstack/react-query'
import { getUserByIdQuery } from '@/query/users'

type UserTabsProps = {
  userID: string | number
}

export const UserTabs: React.FC<UserTabsProps> = ({ userID }) => {
  // ✅ CORRECT: Client component MUST use useQuery directly
  // The prefetched data from server is automatically used via HydrationBoundary
  const { data: user, isLoading, isError } = useQuery(getUserByIdQuery(userID))

  if (!user || isError) return <NotFound title="User not found" />

  return (
    <>
      <PageHeader title={user.name} description={user.email}>
        {/* ... */}
      </PageHeader>
      {/* ... */}
    </>
  )
}
```

### Server Component with Pre-fetching (Edit Pages)

**✅ CORRECT: Use `prefetchQuery` with try-catch and HydrationBoundary for edit pages. Let the client form call `useQuery` directly instead of passing the fetched entity from the server.**

```typescript
import { dehydrate, HydrationBoundary } from '@tanstack/react-query'

import { getQueryClient } from '@/query-client'
import { adminByIdOptions } from '@/query/admins/admins-query'
