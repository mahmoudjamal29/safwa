    await queryClient.prefetchQuery(adminByIdOptions(id))
  } catch (error) {
    console.error(error)
  }

  // Wrap client component with HydrationBoundary to pass dehydrated state
  return (
    <HydrationBoundary state={dehydrate(queryClient)}>
      <AdminForm adminId={id} isEdit />
    </HydrationBoundary>
  )
}
