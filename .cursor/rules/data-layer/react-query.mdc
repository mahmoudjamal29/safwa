  queryOptions<API<TenantById>, AxiosError<API>>({
    queryFn: () =>
      fetcher(ENDPOINTS.TENANTS.GET_BY_ID(tenantId!), {
        auth: true,
        enabled: !!tenantId
      }),
    queryKey: ['tenant-admins', tenantId]
  })

export const getTenantAdminsByTenantIdQuery = (tenantId: number | string) =>
  queryOptions<API<PaginatedResponse<TenantAdmin[]>>, AxiosError<API>>({
