// query/tenants/tenants-mutations.ts
'use client'

import { useRouter } from 'next/navigation'
import { useMutation } from '@tanstack/react-query'
import { AxiosError } from 'axios'
import { fetcher } from '@/lib/fetcher'
import { ENDPOINTS } from '@/query-client'
import { CreateTenantSchema } from '@/app/(app)/tenants/_tenants/form-options/tenants-form-options'

export const useCreateTenantMutation = () => {
  const router = useRouter()
  return useMutation<
    API<unknown>,
    AxiosError<API<unknown>>,
    Omit<CreateTenantSchema, 'status'> & { status: number }
  >({
    meta: { invalidatesQuery: [['tenants']] },
    mutationFn: async (data) =>
      fetcher(ENDPOINTS.TENANTS.POST_ADD_TENANT, {
        auth: true,
        body: data,
        method: 'POST'
      }),
    onSuccess: () => {
      router.push('/tenants')
    }
  })
}

export const useDeleteTenantMutation = () =>
  useMutation<API<unknown>, AxiosError<API<unknown>>, number | string>({
    meta: { invalidatesQuery: [['tenants']] },
    mutationFn: async (tenantId) =>
      fetcher(ENDPOINTS.TENANTS.DELETE(tenantId), {
        auth: true,
        method: 'DELETE'
      })
  })

export const useUpdateContractMutation = (tenantId: number | string) =>
  useMutation<API, AxiosError<API>, ContractFormSchema>({
    meta: { invalidatesQuery: [['tenants', tenantId, 'contract']] },
    mutationFn: async (data) =>
      fetcher(ENDPOINTS.TENANTS.CONTRACT.PUT_UPDATE_CONTRACT(tenantId), {
        auth: true,
        body: data,
        method: 'PUT'
      })
  })
```

